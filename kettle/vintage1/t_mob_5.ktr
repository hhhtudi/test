    <connection>tmp</connection>
    <sql>SELECT 
    t3.loan_time,
    DATE_FORMAT(a.loan_time, '%Y-%m-01') AS loan_date,
    a.loan_no,
    t3.loan_type,
    a.mob,
    a.report_date,
    a.max_days,
    SUM(CASE WHEN t3.repayment_time >= a.min_repayment_time THEN t3.repayment_corpus ELSE 0 END) AS overdue_balance
FROM (
    -- 计算每个统计日期的 min_repayment_time最早逾期时间 和 最大逾期天数max_days
    SELECT 
        t.loan_no,
        t.loan_time,
        t.mob,
        t.report_date,
        MIN(CASE 
                WHEN t.report_date > CURDATE() THEN '2099-12-31'
                WHEN 
                     p.real_repayment_time IS NULL OR t.report_date &lt;= p.real_repayment_time
                THEN p.repayment_time
                ELSE '2099-12-31'
            END) AS min_repayment_time,
        MAX(CASE 
                WHEN t.report_date > CURDATE() THEN 0
                WHEN 
                     p.real_repayment_time IS NULL OR t.report_date &lt;= p.real_repayment_time
                THEN DATEDIFF(t.report_date, p.repayment_time)
                ELSE 0
            END) AS max_days
    FROM (
        -- 生成每个借据每个期数对应的 mob 和统计日期 report_date
        SELECT 
            loan_no,
            loan_time,
            CASE periods
                WHEN 1 THEN 'mob1'
                WHEN 2 THEN 'mob2'
                WHEN 3 THEN 'mob3'
                WHEN 4 THEN 'mob4'
                WHEN 5 THEN 'mob5'
                WHEN 6 THEN 'mob6'
                WHEN 7 THEN 'mob7'
                WHEN 8 THEN 'mob8'
                WHEN 9 THEN 'mob9'
                WHEN 10 THEN 'mob10'
                WHEN 11 THEN 'mob11'
                WHEN 12 THEN 'mob12'
            END AS mob,
            CASE periods
                WHEN 1 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 2 MONTH)
                WHEN 2 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 3 MONTH)
                WHEN 3 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 4 MONTH)
                WHEN 4 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 5 MONTH)
                WHEN 5 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 6 MONTH)
                WHEN 6 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 7 MONTH)
                WHEN 7 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 8 MONTH)
                WHEN 8 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 9 MONTH)
                WHEN 9 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 10 MONTH)
                WHEN 10 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 11 MONTH)
                WHEN 11 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 12 MONTH)
                WHEN 12 THEN DATE_ADD(DATE_FORMAT(loan_time, '%Y-%m-01'), INTERVAL 13 MONTH)
            END AS report_date
        FROM tmp_db.t_repay_plan_record
         WHERE periods BETWEEN 1 AND 12
         -- order_no = 'DO250629110500000039'
          -- AND periods BETWEEN 1 AND 12
        UNION ALL
        -- 添加 mob13 行
        SELECT 
            loan_no,
            MIN(loan_time) AS loan_time,
            'mob13' AS mob,
            DATE_ADD(DATE_FORMAT(MIN(loan_time), '%Y-%m-01'), INTERVAL 14 MONTH) AS report_date
        FROM tmp_db.t_repay_plan_record
        -- WHERE order_no = 'DO250629110500000039'
        GROUP BY loan_no
    ) t
    LEFT JOIN tmp_db.t_repay_plan_record p 
        ON t.loan_no = p.loan_no 
        where t.mob = 'mob5' and date(DATE_ADD(DATE_ADD(t.loan_time, INTERVAL -DAY(t.loan_time) + 1 DAY), INTERVAL 6 MONTH)) = date_add(curdate(),interval -day(curdate())+1 day)
        -- AND p.order_no = 'DO250629110500000039'
    GROUP BY 
        t.loan_no,
        t.loan_time,
        t.mob,
        t.report_date
) a
LEFT JOIN tmp_db.t_repay_plan_record t3 
    ON a.loan_no = t3.loan_no 
    -- AND t3.order_no = 'DO250629110500000039'
GROUP BY 
    DATE_FORMAT(a.loan_time, '%Y-%m-01'),
    a.loan_no,
    t3.loan_type,
    a.mob,
    a.report_date,
    a.max_days;</sql>
